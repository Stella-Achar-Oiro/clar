# Replace with your actual Clerk publishable key from https://dashboard.clerk.com/last-active?path=api-keys
# The key must be in the format: pk_test_<base64(frontendApi$)> for dev or pk_live_<base64(frontendApi$)> for prod
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_API_URL=http://localhost:8000
